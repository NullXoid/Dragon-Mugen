;---------------------------------------------------------------------------
; GUARD (start)
[Statedef 120]
type = U    ;Leave state type unchanged
physics = U ;Leave physics unchanged

[State 120, 1]
type = ChangeAnim
trigger1 = Time = 0
value = 120 + (statetype = C) + (statetype = A)*2

[State 120, 2]
type = StateTypeSet
trigger1 = Time = 0 && statetype = S
physics = S

[State 120, 3]
type = StateTypeSet
trigger1 = Time = 0 && statetype = C
physics = C

[State 120, 4]
type = StateTypeSet
trigger1 = Time = 0 && statetype = A
physics = A

[State 120, Hi to Lo]
type = StateTypeSet
trigger1 = !var(25)
trigger1 = statetype = S && command = "holddown"
trigger2 = var(25)
trigger2 = statetype!=A
trigger2 = (p2statetype!=A || enemynear(var(77)),hitdefattr=SC) && p2movetype=A
statetype = C
physics = C

[State 120, Lo to Hi]
type = StateTypeSet
trigger1 = !var(25)
trigger1 = statetype = C && command != "holddown"
trigger2 = var(25)
trigger2 = statetype!=A
trigger2 = (p2statetype=A || enemynear(var(77)),hitdefattr=A) && p2movetype=A
statetype = S
physics = S

[State 120, 5]
type = ChangeState
trigger1 = AnimTime = 0
value = 130 + (statetype = C) + (statetype = A)*2

[State 120, Stop Guarding]
type = ChangeState
trigger1 = !var(25)
trigger1 = command != "holdback"
trigger2 = !var(25)
trigger2 = !inguarddist
trigger3 = statetype!=A
trigger3 = var(25)
trigger3 = p2movetype!=A
trigger4 = !var(25)
trigger4 = !inguarddist
trigger4 = statetype!=A
value = 140

