[Statedef 40]
type = S
physics = S
anim = 40
ctrl = 0
sprpriority = 1


[State 40, 1]
type = changestate
triggerall = var(25)
triggerall = !time
triggerall = p2bodydist x<=60
triggerall = p2stateno!=5120 && p2stateno!=5200 && p2stateno!=5201 && p2statetype!=L
trigger1 = p2statetype!=A && !(p2statetype=C && p2movetype=A) || p2statetype=A && p2bodydist x<=80 && enemynear(var(77)),vel x>=0 && p2stateno<1000
value = 0
ctrl = 1

[State 40, 1]
type = changestate
triggerall = var(25)
triggerall = !time
trigger1 = p2stateno > 2000
trigger2 = p2movetype=A && p2bodydist x<=60
trigger3 = p2movetype=A && enemynear(var(77)),vel x>=0 && p2bodydist x<=80 && p2stateno =[1000,1999]
trigger4 = p2movetype=A && enemynear(var(77)),vel x>=0 && p2bodydist x<=80 && p2stateno =[1000,1999]
value = 0
ctrl = 1

[state -3,guard]
type = changestate
value = 0
ctrl = 1
triggerall = var(25)
triggerall = statetype!=A
triggerall = p2stateno != [0,1000)
trigger1 = p2bodydist x<=80 && p2dist y>=-100
trigger1 = p2statetype=A && enemynear(var(77)),vel y>=0 && p2movetype=A && random<=400 ;ïŋ―ïŋ―ïŋ―Ô·ïŋ―Íŧïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―
trigger2 = enemynear(var(77)),numproj>0
trigger2 = inguarddist && random<=500   ;ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―
trigger3 = (p2bodydist x=[0,40]) && p2movetype=A && random<=150  ;ïŋ―Å―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ÐĄïŋ―Ðļïŋ―ïŋ―ïŋ―
trigger3 = inguarddist
trigger4 = p2movetype= A && p2bodydist x<=60 && p2statetype != L
trigger5 = (p2stateno = [2000,4999]) && (p2statetype != L) && random<=999     ;ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―Ðļïŋ―ïŋ―ïŋ―
trigger6 = p2bodydist x<=80 && p2dist y>=-100
trigger6 = p2statetype=A && enemynear(var(77)),vel y>=0 && p2movetype=A && random<=350 ;ïŋ―ïŋ―Ôķïŋ―ïŋ―ïŋ―ïŋ―Íŧïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―
trigger7 = p2movetype = A
trigger7 = (p2bodydist x=[15,50])
trigger7 = random <= 250
trigger7 = p2stateno <1000


[State 40, 1]
type = changestate
triggerall = var(25)
triggerall = !time
trigger1 = var(35)
value = 0
ctrl = 1

[State 40, 1]
type = VarSet
trigger1 = Time = 0
sysvar(1) = 0

[State 40, 2]
type = VarSet
triggerall = var(25)
trigger1 = 1
sysvar(1) = 1

[State 40, 1]
type = changestate
triggerall = var(25)
triggerall = !time
trigger1 = random = [200,999]
value = 0
ctrl = 1

[State 40, 2]
type = VarSet
triggerall = var(25)
triggerall = !time
trigger1 = p2bodydist x=[40,100]
trigger1 = p2statetype=A && p2movetype!=H
trigger2 = p2bodydist x<=100 && enemynear(var(77)),vel x>3 && p2movetype=A && p2stateno>=3000
sysvar(1) = -1

[State 40, 2]
type = VarSet
trigger1 = !var(25)
trigger1 = command = "holdfwd"
sysvar(1) = 1

[State 40, 3]
type = VarSet
trigger1 = !var(25)
trigger1 = command = "holdback"
sysvar(1) = -1

[State 40, 4]
type = VelSet
trigger1 = AnimTime = 0
x = ifelse(sysvar(1)=0, const(velocity.jump.neu.x), ifelse(sysvar(1)=1, const(velocity.jump.fwd.x), const(velocity.jump.back.x)))
y = const(velocity.jump.y)

[State 40, 5]
type = VelSet
trigger1 = !var(25)
trigger1 = AnimTime = 0
trigger1 = prevstateno = 100 ;RUN_FWD
trigger1 = sysvar(1) = 1
x = const(velocity.runjump.fwd.x)

[State 40, 6]
type = ChangeState
trigger1 = AnimTime = 0
value = 50
ctrl = 1

