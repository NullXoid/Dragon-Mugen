[Statedef 50]
type = A
physics = A

[State 0]
	type = PlaySnd
	trigger1 = Time = 0
	value = s50, 0
	channel = 1

[State 0]
	type = ChangeAnim
	trigger1 = Time = 0
	trigger1 = sysfvar(1) < 2
	value = ifelse((vel x)=0, 41, ifelse((vel x)>0, 42, 43))

[State 0]
	type = ChangeAnim
	trigger1 = Time = 0
	trigger1 = sysfvar(1)>=2
	value = 41

[State 0]
	type = ChangeAnim
	trigger1 = Vel y > -2
	trigger1 = SelfAnimExist(anim + 3)
	persistent = 0
	value = Anim + 3

[State 0]
	type = AfterImage
	trigger1 = Time = 0
	trigger1 = sysfvar(1)=1 || sysfvar(1)=3
	time = 12
	length = 8
	framegap = 4
	palbright = 1,1,1
	palcontrast = 128,128,128
	paladd = 0,0,0
	palmul = 1,1,1
	trans = add1

